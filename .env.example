# AgentFuse Configuration

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Database
DATABASE_URL=postgresql://agentfuse:agentfuse@localhost:5432/agentfuse
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Classifier
CLASSIFIER_MODEL_PATH=models/deberta-classifier
CLASSIFIER_BATCH_SIZE=32
CLASSIFIER_DEVICE=cpu
CLASSIFIER_CACHE_SIZE=1000

# Policy
POLICY_CONFIG_PATH=config/policies.yaml
MAX_ACTION_HISTORY=5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# MCP
MCP_TIMEOUT_SECONDS=30
MCP_MAX_CONCURRENT=10

# Admin
ADMIN_SECRET_KEY=change-me-in-production
